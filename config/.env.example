# config/.env.example
# Exemplo de configuração para o ambiente de testes OCPP
# Copie este arquivo para .env e ajuste os valores conforme necessário

# URL base do websocket do servidor SteVe (sem station_id)
WS_URL=ws://localhost:8080/steve/websocket/CentralSystemService/

# Identificador do posto (Charge Point)
STATION_ID=CP_1

# Número do conector utilizado nas transações
CONNECTOR_ID=1

# Modelo do posto (Charge Point)
CP_MODEL=Optimus

# Fabricante do posto (Charge Point)
CP_VENDOR=The Mobility House

# Identificador do veículo 
ID_TAG=CARD123

# Intervalo entre heartbeats (em segundos)
HEARTBEAT_INTERVAL=60

# Timeout para estabelecer conexão websocket (segundos)
CONNECTION_TIMEOUT=30

# Timeout para aguardar resposta a chamadas OCPP (segundos)
RESPONSE_TIMEOUT=30

# Número máximo de tentativas de reconexão
MAX_RETRIES=50

# Atraso base para backoff (segundos)
BASE_DELAY=5.0